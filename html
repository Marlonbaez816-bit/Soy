<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Marlon Baez Mendez | Fundador de SoyCubano</title>
    <meta name="description" content="Perfil oficial de Marlon Baez Mendez, fundador de SoyCubano. Desarrollador de plataformas, conoce mi trabajo, visión y cómo conectar.">
    <meta property="og:title" content="Marlon Baez Mendez | SoyCubano">
    <meta property="og:description" content="Conoce al fundador de SoyCubano, un ecosistema de identidad digital segura y descentralizada.">
    <meta property="og:image" content="https://drive.google.com/thumbnail?id=1wNbYUjDgFZJVQwWZNxwWd3EIM_r1ciDU&sz=w1200-h630">
    <meta property="og:type" content="profile">
    <meta name="twitter:card" content="summary_large_image">
    
    <style>
        /* ========== RESET Y VARIABLES ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            background: #f8fafc;
            color: #0f172a;
            line-height: 1.5;
        }

        /* Fondo con efecto de red neuronal/tech */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 25% 40%, rgba(59, 130, 246, 0.03) 0%, transparent 50%),
                              radial-gradient(circle at 75% 80%, rgba(139, 92, 246, 0.03) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
        }

        /* ========== CONTENEDOR PRINCIPAL ========== */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* ========== TARJETA PRINCIPAL (Efecto Glassmorfismo Avanzado) ========== */
        .profile-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(0px);
            border-radius: 56px;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.15), 0 1px 2px rgba(0, 0, 0, 0.02);
            overflow: hidden;
            margin-bottom: 2rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border: 1px solid rgba(203, 213, 225, 0.5);
        }
        .profile-card:hover {
            box-shadow: 0 30px 50px -15px rgba(0, 0, 0, 0.2);
        }

        /* ========== HEADER CON FOTO ARRIBA DERECHA ========== */
        .profile-header {
            display: flex;
            justify-content: flex-end;
            padding: 2rem 2rem 0 2rem;
        }

        .profile-photo {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
            box-shadow: 0 15px 30px -10px rgba(0, 0, 0, 0.15);
            border: 4px solid white;
            transition: transform 0.2s ease;
        }

        .profile-photo:hover {
            transform: scale(1.03);
        }

        /* ========== CONTENIDO DEL PERFIL ========== */
        .profile-content {
            padding: 0 2rem 2rem 2rem;
            text-align: center;
        }

        .profile-name {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.25rem;
        }

        .profile-bio {
            font-size: 1.15rem;
            color: #334155;
            max-width: 600px;
            margin: 0.75rem auto 1rem auto;
        }

        /* ========== VERIFICACIÓN Y REPUTACIÓN ========== */
        .verified-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #eef2ff;
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1e3a8a;
            margin-bottom: 1.5rem;
        }

        .stars {
            color: #f5b042;
            letter-spacing: 2px;
            font-size: 1.2rem;
        }

        /* ========== ENLACES SOCIALES ========== */
        .social-links {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 14px;
            margin: 2rem 0;
        }

        .social-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #ffffff;
            padding: 10px 22px;
            border-radius: 60px;
            text-decoration: none;
            color: #1f2937;
            font-weight: 500;
            transition: all 0.2s ease;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }

        .social-link:hover {
            background: #f1f5f9;
            border-color: #94a3b8;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

        /* ========== SECCIONES ========== */
        .section {
            margin: 2.5rem 0;
            text-align: left;
        }

        .section-title {
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 5px solid #3b82f6;
            padding-left: 1rem;
            color: #0f172a;
        }

        /* ========== RED DE CONEXIONES ========== */
        .network-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1.2rem;
        }

        .network-card {
            background: #ffffff;
            padding: 1rem 1.8rem;
            border-radius: 32px;
            flex: 1;
            min-width: 200px;
            border: 1px solid #eef2f8;
            transition: all 0.2s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .network-card:hover {
            border-color: #b9d0f0;
            background: #fafcff;
            transform: translateY(-2px);
        }

        .network-card a {
            text-decoration: none;
            font-weight: 600;
            color: #2563eb;
        }

        /* ========== SECCIÓN DESARROLLADOR (ESTRELLA) ========== */
        .about-highlight {
            background: linear-gradient(120deg, #f0f9ff, #eef2ff);
            border-radius: 40px;
            padding: 1.5rem;
            margin: 1.5rem 0;
            border: 1px solid #cbdffc;
            text-align: center;
        }
        .about-highlight p {
            font-size: 1rem;
            color: #1e293b;
            margin: 1rem 0;
        }

        /* Botones CTA */
        .btn-primary {
            display: inline-block;
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            color: white;
            padding: 0.75rem 1.8rem;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 500;
            margin-top: 0.5rem;
            transition: 0.2s;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #2d4a9e, #5090f7);
            transform: scale(1.02);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        }

        /* Botón de donación estilo Glass */
        .donation-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-top: 1rem;
        }
        .donation-btn {
            background: #eef2ff;
            padding: 12px 24px;
            border-radius: 60px;
            text-decoration: none;
            color: #1e293b;
            font-weight: 600;
            transition: 0.2s;
            border: 1px solid #cbd5e1;
        }
        .donation-btn:hover {
            background: #ffffff;
            transform: translateY(-2px);
            border-color: #3b82f6;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

        /* MARCA DE AGUA PERSONALIZADA */
        .watermark {
            text-align: center;
            padding: 2rem;
            color: rgba(59, 130, 246, 0.25);
            font-size: 0.85rem;
            letter-spacing: 1px;
            font-weight: 500;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
            margin-top: 2rem;
        }

        .footer-link {
            text-align: center;
            margin: 2rem 0 1rem;
        }
        .footer-link a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 600;
        }

        /* Responsive */
        @media (max-width: 700px) {
            .container {
                padding: 1rem;
            }
            .profile-content {
                padding: 0 1.2rem 1.2rem 1.2rem;
            }
            .profile-name {
                font-size: 1.8rem;
            }
            .social-link {
                padding: 6px 16px;
                font-size: 0.85rem;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="profile-card">
        <!-- HEADER con foto arriba derecha -->
        <div class="profile-header">
            <img class="profile-photo" 
                 src="https://drive.google.com/thumbnail?id=1wNbYUjDgFZJVQwWZNxwWd3EIM_r1ciDU&sz=w400-h400" 
                 alt="Foto de perfil de Marlon Baez Mendez" 
                 onerror="this.src='https://via.placeholder.com/140x140?text=Marlon'">
        </div>

        <!-- CONTENIDO PRINCIPAL -->
        <div class="profile-content">
            <h1 class="profile-name">Marlon Baez Mendez</h1>
            <p class="profile-bio">Fundador de <strong>SoyCubano</strong> | Arquitecto de plataformas descentralizadas</p>
            
            <div class="verified-badge">
                <span>✅</span> Fundador Verificado · 
                <span class="stars">⭐⭐⭐⭐⭐</span> 5.0
            </div>

            <!-- REDES SOCIALES (enlaces dinámicos) -->
            <div class="social-links" id="socialLinksContainer"></div>

            <!-- SECCIÓN PROFESIONAL (Perfil destacado) -->
            <div class="section">
                <div class="section-title">🚀 Sobre mí</div>
                <div class="about-highlight">
                    <p>+53 51080807 · marlonbaezmendez1 · <strong>marlonbaez816@gmail.com</strong></p>
                    <p>🔷 <strong>Desarrollador de plataformas</strong> con foco en identidad digital segura, ecosistemas descentralizados y nuevas economías de internet.<br> 
                    🧠 "Sin bases de datos centrales, sin puntos únicos de fallo. La web segura es posible."</p>
                    <a href="https://wa.me/5351080807?text=Hola%20Marlon%2C%20vi%20tu%20perfil%20en%20SoyCubano%20y%20me%20gustaría%20conectar" class="btn-primary" target="_blank">📲 Contáctame vía WhatsApp</a>
                </div>
            </div>

            <!-- ===== RED DE CONEXIONES (Familia / Empresa) ===== -->
            <div class="section">
                <div class="section-title">🔗 Red de Confianza</div>
                <div class="network-grid" id="connectionsContainer"></div>
            </div>

            <!-- ===== DONACIONES Y APOYO DIRECTO ===== -->
            <div class="section">
                <div class="section-title">💰 Apoya este ecosistema</div>
                <div class="donation-buttons" id="donationContainer"></div>
                <p style="margin-top: 1rem; font-size: 0.85rem; color: #475569;">FaucetPay: marlonbaez816@gmail.com</p>
            </div>
        </div>
    </div>

    <!-- MARCA DE AGUA SOYCUBANO -->
    <div class="watermark">
        🌐 SoyCubano — Identidad digital segura · Fundado por Marlon Baez Mendez
    </div>
    <div class="footer-link">
        🔗 <a href="https://soygana.com/preventa">¿Quieres tu propia página personal en nuestra red? Créala aquí</a>
    </div>
</div>

<script>
    // ============================================================
    // CONFIGURACIÓN DE LA PÁGINA
    // ============================================================
    
    // 1. REDES SOCIALES (si no se añaden, no aparecerán)
    const socialLinks = [
        { name: "WhatsApp", url: "https://wa.me/5351080807", icon: "📱" },
        { name: "Instagram", url: "https://instagram.com/marlonbaezmendez1", icon: "📷" },
        { name: "Twitter / X", url: "https://x.com/marlonbaezm", icon: "🐦" },
        { name: "GitHub", url: "https://github.com/marlonbaez", icon: "👨‍💻" }
    ];

    // 2. CONEXIONES (familiares, empresas, colaboradores)
    const connections = [
        { title: "👨‍💼 CEO de SoyCubano", url: "/empresa/soycubano.html" },
        { title: "🤝 Mentor: Programa Web3 Latam", url: "/personas/mentor.html" },
        { title: "🏛️ Colaborador: Comunidad Descentralizada", url: "/comunidad/descentralizados.html" }
    ];

    // 3. DONACIONES (APOYO ECONÓMICO)
    const donations = [
        { name: "🌊 FaucetPay", url: "https://faucetpay.io/page/send?to=marlonbaez816@gmail.com" },
        { name: "🟡 Binance Pay", url: "https://pay.binance.com/es/donate/marlonbaez" },
        { name: "💳 PayPal", url: "https://paypal.me/marlonbaez" },
        { name: "🏦 Transferencia bancaria (CUP)", url: "https://t.me/SoyCubanoBot" }
    ];

    // ============================================================
    // FUNCIONES DE RENDERIZADO
    // ============================================================
    
    function renderSocialLinks() {
        const container = document.getElementById('socialLinksContainer');
        if (!container) return;
        if (!socialLinks.length) {
            container.style.display = 'none';
            return;
        }
        container.innerHTML = socialLinks.map(link => `
            <a href="${link.url}" target="_blank" rel="noopener noreferrer" class="social-link">
                ${link.icon} ${link.name}
            </a>
        `).join('');
    }

    function renderConnections() {
        const container = document.getElementById('connectionsContainer');
        if (!container) return;
        if (!connections.length) {
            container.innerHTML = '<div class="network-card">Red de confianza en expansión...</div>';
            return;
        }
        container.innerHTML = connections.map(conn => `
            <div class="network-card">
                <a href="${conn.url}">${conn.title}</a>
            </div>
        `).join('');
    }

    function renderDonations() {
        const container = document.getElementById('donationContainer');
        if (!container) return;
        if (!donations.length) {
            container.style.display = 'none';
            return;
        }
        container.innerHTML = donations.map(d => `
            <a href="${d.url}" target="_blank" rel="noopener noreferrer" class="donation-btn">✨ Apoyar vía ${d.name}</a>
        `).join('');
    }

    document.addEventListener('DOMContentLoaded', () => {
        renderSocialLinks();
        renderConnections();
        renderDonations();
    });
</script>
</body>
</html>
